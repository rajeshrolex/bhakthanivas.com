{
    "name": "bhakthanivas/backend",
    "description": "BhaktaNivas Lodge Booking System – PHP/MySQL Backend",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^2.0",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
